<idea-plugin>
  <id>com.github.baeyung.pos-lang</id>

  <name>Pos Lang</name>

  <vendor url="https://github.com/Baeyung">Baeyung</vendor>

  <description><![CDATA[
        This plugin allows to add the support for .state and .phtm files. <br>
        <em>
          For any issues that are found please report them
          <a href="https://github.com/Baeyung/openff-issues">here</a>
        </em>
    ]]></description>

  <depends>com.intellij.java</depends>
  <depends>com.intellij.modules.json</depends>
  <depends>org.jetbrains.plugins.yaml</depends>
  <depends>com.intellij.modules.xml</depends>

  <extensions defaultExtensionNs="com.intellij">
    <fileType
        name="State File"
        language="StateLang"
        implementationClass="com.github.baeyung.poslang.statelang.StateFileType"
        extensions="state"
    />
    <lang.syntaxHighlighterFactory
        language="StateLang"
        implementationClass="com.github.baeyung.poslang.statelang.highlighting.StateSyntaxHighlighterFactory"
    />

    <colorSettingsPage
        implementation="com.github.baeyung.poslang.statelang.highlighting.StateColorSettingsPage"
    />

    <lang.parserDefinition
        language="StateLang"
        implementationClass="com.github.baeyung.poslang.statelang.lexer.StateParserDefinition"
    />

    <annotator
        language="StateLang"
        implementationClass="com.github.baeyung.poslang.statelang.spec.StateAnnotator"
    />

    <lang.findUsagesProvider
        language="StateLang"
        implementationClass="com.github.baeyung.poslang.statelang.usage.StateFindUsagesProvider"
    />

    <fileType
        name="Phtm File"
        language="PhtmLang"
        implementationClass="com.github.baeyung.poslang.phtmlang.PhtmFileType"
        extensions="phtm"
    />
      <completion.contributor
        language="StateLang"
        implementationClass="com.github.baeyung.poslang.statelang.completion.StateCompletionContributor"
    />
</extensions>
</idea-plugin>
